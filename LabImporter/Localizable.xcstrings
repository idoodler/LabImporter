          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutto avviene sul dispositivo. LabImporter non trasmette mai i tuoi dati di laboratorio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
