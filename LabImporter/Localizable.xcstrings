          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Importez des rapports avec des valeurs numériques pour voir les tendances."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Importa referti con valori numerici per vedere gli andamenti."
          }
        },
        "ja": {
