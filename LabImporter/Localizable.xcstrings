          "stringUnit": {
            "state": "translated",
            "value": "Importa almeno due referti con questo valore per vedere un andamento."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この値を含むレポートを2件以上インポートすると、トレンドが表示されます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Importeer minimaal twee rapporten met deze waarde om een trend te zien."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaimportuj co najmniej dwa raporty zawierające tę wartość, aby zobaczyć trend."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Importe ao menos dois laudos com esse valor para ver uma tendência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Импортируйте не менее двух отчётов с этим значением, чтобы увидеть тренд."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Trend görmek için bu değeri içeren en az iki rapor içe aktarın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Імпортуйте принаймні два звіти з цим значенням, щоб побачити тенденцію."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "导入至少两份包含此数值的报告以查看趋势。"
          }
        }
      }
    },
