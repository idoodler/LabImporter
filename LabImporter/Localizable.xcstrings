    "Photograph your lab report and\nsave it directly to Apple Health.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografiere deinen Laborbericht und\nspeichere ihn direkt in der Gesundheits-App."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografía tu informe de laboratorio y\nguárdalo directamente en Salud."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Photographiez votre rapport de labo et\nenregistrez-le directement dans Santé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografa il tuo referto e\nsalvalo direttamente in Salute."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "検査レポートを撮影して\nヘルスケアに直接保存。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografeer uw labrapport en\nsla het rechtstreeks op in Gezondheid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sfotografuj raport z badań i\nzapisz go bezpośrednio w Zdrowiu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografe seu laudo e\nsalve-o diretamente no Saúde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сфотографируйте лабораторный отчёт и\nсохраните его прямо в Здоровье."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Laboratuvar raporunuzu fotoğraflayın ve\ndoğrudan Sağlık'a kaydedin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сфотографуйте лабораторний звіт і\nзбережіть його прямо у Здоров'ї."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拍摄检验报告，\n直接保存到健康。"
          }
        }
      }
    },
    "Photograph, paste, or scan a report to extract your values.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografiere, füge ein oder scanne einen Bericht, um deine Werte zu extrahieren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografía, pega o escanea un informe para extraer tus valores."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Photographiez, collez ou scannez un rapport pour extraire vos valeurs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografa, incolla o scansiona un referto per estrarre i valori."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "レポートを撮影、貼り付け、またはスキャンして値を抽出。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografeer, plak of scan een rapport om uw waarden te extraheren."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sfotografuj, wklej lub zeskanuj raport, aby wyodrębnić wartości."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Fotografe, cole ou digitalize um laudo para extrair seus valores."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сфотографируйте, вставьте или отсканируйте отчёт, чтобы извлечь значения."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Değerlerinizi çıkarmak için bir raporu fotoğraflayın, yapıştırın veya tarayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
