    "Date of birth and biological sex help label your reports and contextualize values." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geburtsdatum und biologisches Geschlecht helfen, deine Berichte zu kennzeichnen und Werte einzuordnen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fecha de nacimiento y el sexo biológico ayudan a etiquetar tus informes y a contextualizar los valores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La date de naissance et le sexe biologique aident à étiqueter vos rapports et à contextualiser les valeurs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data di nascita e sesso biologico aiutano a etichettare i referti e a contestualizzare i valori."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "生年月日と生物学的性別は、レポートのラベル付けや値の文脈把握に役立ちます。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geboortedatum en biologisch geslacht helpen je rapporten te labelen en waarden te duiden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Data urodzenia i płeć biologiczna pomagają oznaczyć Twoje raporty i osadzić wyniki w kontekście."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A data de nascimento e o sexo biológico ajudam a rotular seus relatórios e contextualizar os valores."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дата рождения и биологический пол помогают подписывать отчёты и понимать значения в контексте."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doğum tarihi ve biyolojik cinsiyet, raporlarınızı etiketlemeye ve değerleri bağlamına oturtmaya yardımcı olur."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дата народження і біологічна стать допомагають підписувати звіти та тлумачити значення."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "出生日期和生理性别有助于标注报告并理解数值。"
          }
        }
      }
    },
