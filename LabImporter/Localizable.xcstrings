    "You can show this value again anytime in Settings → Sort & Visibility.": {
      "comment": "Explanation shown in the hide confirmation dialog telling the user where to re-enable the value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kannst diesen Wert jederzeit unter Einstellungen → Sortierung & Sichtbarkeit wieder einblenden."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes volver a mostrar este valor cuando quieras en Ajustes → Orden y visibilidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez réafficher cette valeur à tout moment dans Réglages → Tri et visibilité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Puoi mostrare di nuovo questo valore in qualsiasi momento in Impostazioni → Ordine e visibilità."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この検査値は、設定 → 並び替えと表示 でいつでも再表示できます。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je kunt deze waarde later weer tonen via Instellingen → Sorteren en zichtbaarheid."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz ponownie pokazać tę wartość w Ustawienia → Sortowanie i widoczność."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você pode exibir este valor novamente em Ajustes → Ordem e visibilidade."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы можете снова показать это значение в Настройки → Сортировка и видимость."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu değeri istediğin zaman Ayarlar → Sıralama ve Görünürlük bölümünden yeniden gösterebilirsin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви можете знову показати це значення в Налаштування → Сортування та видимість."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你可以随时在设置 → 排序与可见性中重新显示该检验值。"
          }
        }
      }
    },
