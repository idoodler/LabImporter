    "You can turn iCloud sync on or off later in Settings." : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Можете да включите или изключите синхронизацията с iCloud по-късно в Настройки."
          }
        },
        "ca" : {
          "stringUnit" : {
