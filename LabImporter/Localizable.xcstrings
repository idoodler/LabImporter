    "Everything runs on-device. LabImporter never transmits your lab data." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles läuft auf deinem Gerät. LabImporter überträgt deine Labordaten nie."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todo se procesa en tu dispositivo. LabImporter nunca transmite tus datos de laboratorio."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout se passe sur l’appareil. LabImporter ne transmet jamais vos données de laboratoire."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutto avviene sul dispositivo. LabImporter non trasmette mai i tuoi dati di laboratorio."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてデバイス上で処理されます。LabImporterが検査データを送信することはありません。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles gebeurt op je apparaat. LabImporter verstuurt je labgegevens nooit."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystko dzieje się na urządzeniu. LabImporter nigdy nie wysyła Twoich danych laboratoryjnych."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tudo é processado no dispositivo. O LabImporter nunca transmite seus dados laboratoriais."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Всё происходит на устройстве. LabImporter никогда не передаёт ваши лабораторные данные."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
