        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画像に検査値が見つかりませんでした。レポートがはっきり見えるか確認してください。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen labwaarden gevonden in deze afbeelding. Zorg ervoor dat het rapport goed zichtbaar is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie znaleziono wartości badań na tym zdjęciu. Upewnij się, że raport jest wyraźnie widoczny."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Nenhum valor encontrado nesta imagem. Certifique-se de que o laudo esteja claramente visível."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом изображении не найдено лабораторных значений. Убедитесь, что отчёт хорошо виден."
          }
        },
        "tr": {
          "stringUnit": {
