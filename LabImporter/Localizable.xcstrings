    "No values can be exported. Make sure at least one value is enabled and has a numeric result." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine Werte können exportiert werden. Stellen Sie sicher, dass mindestens ein Wert aktiviert ist und ein numerisches Ergebnis hat."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pueden exportar valores. Asegúrate de que al menos un valor esté habilitado y tenga un resultado numérico."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucune valeur ne peut être exportée. Assurez-vous qu'au moins une valeur est activée et a un résultat numérique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nessun valore esportabile. Assicurati che almeno un valore sia abilitato e abbia un risultato numerico."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "書き出せる値がありません。少なくとも1つの値が有効で数値の結果を持つことを確認してください。"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geen waarden kunnen worden geëxporteerd. Zorg dat er minstens één waarde ingeschakeld is met een numeriek resultaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie można wyeksportować żadnych wartości. Upewnij się, że co najmniej jedna wartość jest włączona i ma wynik numeryczny."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nenhum valor pode ser exportado. Certifique-se de que pelo menos um valor esteja ativado e tenha um resultado numérico."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нет значений для экспорта. Убедитесь, что хотя бы одно значение включено и имеет числовой результат."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dışa aktarılacak değer yok. En az bir değerin etkin olduğundan ve sayısal bir sonucu olduğundan emin olun."
