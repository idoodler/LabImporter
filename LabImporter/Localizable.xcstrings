    "Apple Intelligence reads your report privately — nothing leaves your device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence liest deinen Bericht privat – nichts verlässt dein Gerät."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence lee tu informe de forma privada — nada sale de tu dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence lit votre rapport en toute confidentialité — rien ne quitte votre appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence legge il tuo referto in modo privato — nulla lascia il tuo dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligenceはレポートをプライベートに処理します — データはデバイスの外に出ません。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence leest uw rapport privé — er verlaat niets uw apparaat."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence czyta Twój raport prywatnie — nic nie opuszcza Twojego urządzenia."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Apple Intelligence lê seu laudo de forma privada — nada sai do seu dispositivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence читает ваш отчёт конфиденциально — ничего не покидает ваше устройство."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence raporunuzu gizli olarak okur — cihazınızdan hiçbir şey çıkmaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence читає ваш звіт конфіденційно — нічого не залишає ваш пристрій."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Intelligence 以私密方式读取您的报告 — 数据不会离开您的设备。"
          }
        }
      }
    },
